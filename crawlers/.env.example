# Direct Postgres connection string from Supabase
# Project Settings → Database → Connection string (URI tab)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Crawler behaviour (optional — these are the defaults)
CRAWL_RATE_LIMIT=2.0          # seconds between requests to the same host
MAX_THREADS_PER_SOURCE=20     # max threads to crawl per source URL
MAX_POSTS_PER_THREAD=100      # max posts to extract per thread
REQUEST_TIMEOUT=30            # HTTP request timeout in seconds
